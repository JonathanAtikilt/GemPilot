# Copy to .env on your OpenClaw / Brev backend instance.
# RAG and the orchestrator share NVIDIA + Supabase; all marked REQUIRED must be set for live runs.

ADAPTER_MODE=live
MVPILOT_MOCK_TOOLS=false

# REQUIRED — Nemotron orchestrator
NVIDIA_API_KEY=

# REQUIRED — RAG storage + embeddings (same NVIDIA key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NVIDIA_EMBED_MODEL=llama-nemotron-embed-1b-v2
NVIDIA_RERANK_MODEL=llama-nemotron-rerank-1b-v2

# OpenClaw platform
OPENCLAW_API_KEY=
OPENCLAW_ENV=production

# Optional RAG web sources (also edit rag/scrape_urls.txt)
RAG_SCRAPE_URLS=

# Nemotron models
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_FAST_MODEL=nvidia/nvidia-nemotron-nano-9b-v2
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# GitHub tools (Person 3)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO_PREFIX=mvpilot-generated-

# CORS for your deployed frontend origin
CORS_ORIGINS=https://your-frontend.example.com

# After deploy: run once
# curl -X POST http://127.0.0.1:3001/rag/ingest
# curl http://127.0.0.1:3001/health  # expect rag_configured: true
