# --- Runtime ---
ADAPTER_MODE=live
MOCK_MODE=false
MVPILOT_MOCK_TOOLS=false

# Enable this for student demos when you want provider failures to return
# idea-specific partial output instead of stopping the whole workflow.
# Set false for strict live testing (no degraded/partial/Groq fallbacks).
ALLOW_IDEA_AWARE_PARTIAL=false
REQUIRE_LIVE_FILE_MANIFEST=true
LLM_FAST_FALLBACK=false

# --- LLM provider ---
# Supported: gemini | groq | openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# Optional fallback/fast model. If GROQ_API_KEY is set and LLM_PROVIDER is not
# groq, the backend automatically falls back to Groq for structured JSON calls.
LLM_FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional provider base URL overrides
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- LLM reliability / output sizing ---
LLM_TIMEOUT_SECONDS=300
LLM_STRICT_TIMEOUT_SECONDS=300
LLM_FILE_MANIFEST_TIMEOUT_SECONDS=600
LLM_REPO_PLAN_TIMEOUT_SECONDS=600
LLM_MAX_RETRIES=2
LLM_REPO_PLAN_MAX_RETRIES=3
LLM_REASONING_EFFORT=none
LLM_PLANNING_MAX_TOKENS=2500
LLM_STACK_RECOMMENDATION_MAX_TOKENS=4000
LLM_REPO_PLAN_MAX_TOKENS=6000
LLM_FILE_MANIFEST_MAX_TOKENS=3500
LLM_FILE_MANIFEST_MAX_RETRIES=3

# --- RAG ---
# Defaults use Gemini embeddings with the same GEMINI_API_KEY as the LLM.
# To use OpenAI embeddings instead, set EMBEDDING_PROVIDER=openai and keep
# OPENAI_API_KEY populated.
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: comma-separated URLs merged with rag/scrape_urls.txt at ingest time.
RAG_SCRAPE_URLS=

# --- GitHub OAuth ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/api/auth/github/callback
GITHUB_TOKEN_ENCRYPTION_KEY=
# Optional PAT fallback for repo creation when OAuth is unavailable.
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_OWNER=

# --- Frontend CORS ---
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_API_URL=http://127.0.0.1:3001
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
