# --- Orchestrator (Person 1) ---
# Use live for real Nemotron + enriched OpenClaw workflow.
ADAPTER_MODE=live
MOCK_MODE=false

# --- Pure live Nemotron (30–60 min runs, no partial fallback) ---
ALLOW_IDEA_AWARE_PARTIAL=false
NEMOTRON_FAST_FALLBACK=false
REQUIRE_LIVE_FILE_MANIFEST=true
NEMOTRON_TIMEOUT_SECONDS=900
NEMOTRON_STRICT_TIMEOUT_SECONDS=900
NEMOTRON_FILE_MANIFEST_TIMEOUT_SECONDS=1200
NEMOTRON_REPO_PLAN_TIMEOUT_SECONDS=1200
NEMOTRON_MAX_RETRIES=3
NEMOTRON_REPO_PLAN_MAX_RETRIES=5
NEMOTRON_POLL_ATTEMPTS=120
NEMOTRON_POLL_INTERVAL_SECONDS=2
NEMOTRON_POLL_MAX_SECONDS=3600
NEMOTRON_FILE_MANIFEST_POLL_MAX_SECONDS=3600
NEMOTRON_REPO_PLAN_POLL_MAX_SECONDS=3600
NEMOTRON_REASONING_EFFORT=none
NEMOTRON_PLANNING_MAX_TOKENS=2500
NEMOTRON_STACK_RECOMMENDATION_MAX_TOKENS=4000
NEMOTRON_REPO_PLAN_MAX_TOKENS=6000
NEMOTRON_FILE_MANIFEST_MAX_TOKENS=3500
NEMOTRON_FILE_MANIFEST_MAX_RETRIES=5

# --- Fast demo profile (uncomment instead of pure live above) ---
# ALLOW_IDEA_AWARE_PARTIAL=true
# NEMOTRON_FAST_FALLBACK=true
# REQUIRE_LIVE_FILE_MANIFEST=false
# NEMOTRON_LIVE_ATTEMPT_TIMEOUT_SECONDS=75
# NEMOTRON_FAST_FALLBACK_MAX_RETRIES=0
# NEMOTRON_FAST_FALLBACK_POLL_MAX_SECONDS=90

# --- NVIDIA / Nemotron (required for live orchestrator + RAG embed/rerank) ---
NVIDIA_API_KEY=
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_FAST_MODEL=nvidia/nvidia-nemotron-nano-9b-v2
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# --- RAG (Person 2) — required for ingest, search, and orchestrator retrieve_context ---
# Without these three, /rag/* and workflow RAG steps return configuration errors.
NVIDIA_EMBED_MODEL=llama-nemotron-embed-1b-v2
NVIDIA_RERANK_MODEL=llama-nemotron-rerank-1b-v2
# Optional overrides (defaults work for Nemotron NIM):
# NVIDIA_EMBEDDING_URL=https://integrate.api.nvidia.com/v1/embeddings
# NVIDIA_RERANK_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: comma-separated URLs merged with rag/scrape_urls.txt at ingest time
RAG_SCRAPE_URLS=

# --- OpenClaw (hackathon agent host) ---
# Set in the OpenClaw deployment / Brev instance env alongside RAG vars above.
OPENCLAW_API_KEY=
OPENCLAW_GATEWAY_TOKEN=
# e.g. development | staging | production (platform-specific; used for logging/config)
OPENCLAW_ENV=development
# Optional OpenClaw API base URL if your tenant uses a non-default host
# OPENCLAW_BASE_URL=

# --- GitHub OAuth (Person 3) ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/api/auth/github/callback
GITHUB_TOKEN_ENCRYPTION_KEY=
# Optional PAT fallback for repo creation when OAuth is unavailable
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_OWNER=

# --- Frontend CORS ---
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- Tooling ---
MVPILOT_MOCK_TOOLS=false
