# --- Orchestrator (Person 1) ---
# Use live for real Nemotron + enriched OpenClaw workflow.
ADAPTER_MODE=live
MOCK_MODE=false
# When Nemotron is unavailable, generate a logged, idea-specific partial MVP.
ALLOW_IDEA_AWARE_PARTIAL=true

# --- NVIDIA / Nemotron (required for live orchestrator + RAG embed/rerank) ---
NVIDIA_API_KEY=
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_FAST_MODEL=nvidia/nvidia-nemotron-nano-9b-v2
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_TIMEOUT_SECONDS=30
NEMOTRON_MAX_RETRIES=1
NEMOTRON_POLL_ATTEMPTS=3
NEMOTRON_POLL_INTERVAL_SECONDS=1

# --- RAG (Person 2) — required for ingest, search, and orchestrator retrieve_context ---
# Without these three, /rag/* and workflow RAG steps return configuration errors.
NVIDIA_EMBED_MODEL=llama-nemotron-embed-1b-v2
NVIDIA_RERANK_MODEL=llama-nemotron-rerank-1b-v2
# Optional overrides (defaults work for Nemotron NIM):
# NVIDIA_EMBEDDING_URL=https://integrate.api.nvidia.com/v1/embeddings
# NVIDIA_RERANK_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: comma-separated URLs merged with rag/scrape_urls.txt at ingest time
RAG_SCRAPE_URLS=

# --- OpenClaw (hackathon agent host) ---
# Set in the OpenClaw deployment / Brev instance env alongside RAG vars above.
OPENCLAW_API_KEY=
OPENCLAW_GATEWAY_TOKEN=
# e.g. development | staging | production (platform-specific; used for logging/config)
OPENCLAW_ENV=development
# Optional OpenClaw API base URL if your tenant uses a non-default host
# OPENCLAW_BASE_URL=

# --- Supabase (frontend read-only) ---
SUPABASE_ANON_KEY=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# --- Backend-owned GitHub OAuth (required for "Connect GitHub" in the UI) ---
# Create a GitHub OAuth App: https://github.com/settings/developers
# Homepage URL: http://localhost:3000
# Callback URL must match GITHUB_OAUTH_REDIRECT_URI exactly.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/api/auth/github/callback
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=
# Aliases still supported:
# GITHUB_CLIENT_ID= / GITHUB_CLIENT_SECRET= / GITHUB_REDIRECT_URI=

# --- Person 3 tool layer ---
MVPILOT_MOCK_TOOLS=false
GITHUB_REPO_PREFIX=mvpilot-generated-
# Legacy local-only backend-token fallback is disabled by default and is not used by the website.
# GITHUB_ENV_TOKEN_FALLBACK_ENABLED=false
# GITHUB_TOKEN=
# GITHUB_OWNER=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_AGENT_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
